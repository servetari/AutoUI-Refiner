OPENROUTER_API_KEY=your_api_key_here
# gpt-4o-mini is cheap but tends to parrot the prompt instead of critiquing the
# screenshot. For reliable evaluations use a stronger vision model, e.g.:
#   openai/gpt-4o  |  google/gemini-2.5-flash  |  qwen/qwen2.5-vl-72b-instruct
VISION_MODEL=openai/gpt-4o-mini
CODER_MODEL=deepseek/deepseek-chat
